# Supabase Configuration
# Get these values from your Supabase project dashboard:
# Settings → API

# Project URL (e.g., https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon/Public Key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-her
# Service Role Key (NEVER expose to browser, server-side only)
# This key bypasses Row Level Security - keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET_NAME=
SUPABASE_STORAGE_BUCKET_URL_PREFIX=
# to remind supabase free tier limit
STORAGE_LIMIT_MB=500

# Stripe Configuration (Test Mode)
# Get from: Stripe Dashboard → Developers → API Keys
# IMPORTANT: Only use sk_test_... / pk_test_... keys in development!
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: running `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
EMPLOYER_IDENTIFICATION_NUMBER=

# Cloudflare Turnstile
# Get from: Cloudflare Dashboard → Turnstile → your widget
# Site Key is public (rendered in the browser); Secret Key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Donation amount upper bound, in USD. Defaults to 10000 if unset.
DONATION_AMOUNT_MAX_USD=10000