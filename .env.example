# Supabase Configuration
# Get these values from your Supabase project dashboard:
# Settings → API

# Project URL (e.g., https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (NEVER expose to browser, server-side only)
# This key bypasses Row Level Security - keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Project Reference ID (for type generation)
NEXT_PUBLIC_SUPABASE_PROJECT_REF=your-project-ref-id
